# Option A: Source-code installation path (for developers who cloned the repo)
# Set this to the root of your local video-helper project (contains both frontend and backend).
# Example: VIDEO_HELPER_SOURCE_DIR=D:\video-helper
VIDEO_HELPER_SOURCE_DIR=

# Option B: Docker compose auto-start
# Default is enabled. Set to 0 to disable docker auto-start and use desktop/source only.
VIDEO_HELPER_ENABLE_DOCKER_AUTOSTART=1

# (Optional) Custom service URLs
# Change these if you use non-default ports or hostnames.
VIDEO_HELPER_API_URL=http://localhost:8000/api/v1
VIDEO_HELPER_FRONTEND_URL=http://localhost:3000

# Option B: Desktop client installation directory (for users who installed the app)
# Leave blank to auto-detect the default system install location.
# Only needed if you installed the app to a non-default location.
# Example: VIDEO_HELPER_DESKTOP_INSTALL_DIR=C:\Users\me\AppData\Local\Programs\Video Helper
VIDEO_HELPER_DESKTOP_INSTALL_DIR=
